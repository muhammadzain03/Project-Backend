# MySQL
DATABASE_HOST=127.0.0.1
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=userdb
DATABASE_PORT=3306
DB_POOL_SIZE=20

# Google Cloud Storage
GCS_BUCKET=your_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=credentials/your-service-account-key.json

# Frontend (optional):
# Leave VITE_API_URL unset in dev so the Vite proxy handles routing.
# Only set it when calling the API directly (e.g. deployed Cloud Run URL).
# VITE_API_URL=http://127.0.0.1:5000
